# Supabase (required for app and API routes)
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (server-side only; never expose to the client)
# Required for admin APIs, cron, and server-side DB access
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: use if you want to override URL/keys for server-side only
# SUPABASE_URL=https://your-project-ref.supabase.co

# Stripe (required for paid plans and promotions)
# Get from: Stripe Dashboard → Developers → API keys (use live keys for production)
STRIPE_SECRET_KEY=sk_live_xxx
# Webhook signing secret (Stripe Dashboard → Webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Business plans (subscription price IDs)
# STRIPE_PRICE_STARTER=price_xxx
# STRIPE_PRICE_GROWTH=price_xxx
# STRIPE_PRICE_PREMIUM=price_xxx

# Promotion / placard (one-time payment price IDs; tier + duration in days)
# Create one-time payment products in Stripe, then add each Price ID here.
# STRIPE_PRICE_PROMO_BASIC_14=price_xxx
# STRIPE_PRICE_PROMO_BASIC_30=price_xxx
# STRIPE_PRICE_PROMO_BASIC_90=price_xxx
# STRIPE_PRICE_PROMO_BASIC_180=price_xxx
# STRIPE_PRICE_PROMO_BASIC_365=price_xxx
# STRIPE_PRICE_PROMO_TARGETED_14=price_xxx
# STRIPE_PRICE_PROMO_TARGETED_30=price_xxx
# STRIPE_PRICE_PROMO_TARGETED_90=price_xxx
# STRIPE_PRICE_PROMO_TARGETED_180=price_xxx
# STRIPE_PRICE_PROMO_TARGETED_365=price_xxx
# STRIPE_PRICE_PROMO_PREMIUM_14=price_xxx
# STRIPE_PRICE_PROMO_PREMIUM_30=price_xxx
# STRIPE_PRICE_PROMO_PREMIUM_90=price_xxx
# STRIPE_PRICE_PROMO_PREMIUM_180=price_xxx
# STRIPE_PRICE_PROMO_PREMIUM_365=price_xxx
